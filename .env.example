# Copy to .env and fill in before deploying.

# Your real production domain (no trailing slash).
# Used for canonical URLs, hreflang, sitemap and JSON-LD.
SITE_URL=https://tudominio.com

# ── Kelvo Pro (one-time purchase via Lemon Squeezy) ──
# Hosted checkout link, e.g. https://kelvo.lemonsqueezy.com/buy/XXXXXXXX
# While empty, the /pro page shows "Coming soon" instead of a buy button.
PRO_CHECKOUT_URL=
# Lemon Squeezy store id (number) — used by the client-side license API.
PRO_STORE_ID=
# Price shown on the /pro page (display only). Default: US$9
PRO_PRICE=
