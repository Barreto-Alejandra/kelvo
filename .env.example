# Copy to .env and fill in before deploying.

# Your real production domain (no trailing slash).
# Used for canonical URLs, hreflang, sitemap and JSON-LD.
SITE_URL=https://tudominio.com

# Google AdSense publisher id, e.g. ca-pub-1234567890123456
# Leave empty to show NO ads (recommended until AdSense approves your site).
ADSENSE_CLIENT=
