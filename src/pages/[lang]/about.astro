---
import { SITE, CONTACT, type Locale } from '@/config';
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return SITE.locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const path = `/${locale}/about`;
const mail = CONTACT.email;

const C = {
  en: {
    title: 'About Kelvo',
    desc:
      'Single-purpose web tools that run entirely in your browser — no signup, no upload, no tracking. Free, fast and private by design.',
    lede:
      'Kelvo is a small collection of web tools that each do one thing well — generate a password, compress an image, build a QR code — with no signup, no uploads and no tracking.',
    sections: [
      {
        h: 'Why Kelvo exists',
        body: [
          'Most “free” online tools hide the real cost. They upload your files to a server, bury the page in ads and trackers, or push you to create an account before you can do anything. Kelvo is the opposite of that.',
          'Every tool runs <strong>entirely in your browser</strong>, on your own device. Your files never travel to a server — because there is no server doing the work.',
        ],
      },
      {
        h: 'How it’s built',
        body: [
          'Kelvo is a static site: no backend, no database, no analytics, no cookies for tracking. That’s what makes it fast to load and impossible for us to peek at what you’re doing. Image tools use the browser’s Canvas; the password generator uses Web Crypto — all native, all local.',
        ],
      },
      {
        h: 'Free, no catch',
        body: [
          'Every tool is free, with <strong>no ads and nothing to buy</strong> — including batch processing and one-click ZIP downloads. The best way to support the project is simply to share it with someone who’d find it useful.',
        ],
      },
      {
        h: 'Contact',
        body: [
          'Questions, ideas or found a bug? Email <a href="mailto:' +
            mail +
            '">' +
            mail +
            '</a> — feedback genuinely shapes what gets built next.',
        ],
      },
    ],
    foot: 'Kelvo is an independent project.',
  },
  es: {
    title: 'Acerca de Kelvo',
    desc:
      'Herramientas web de un solo uso que funcionan enteramente en tu navegador: sin registro, sin subir nada, sin rastreo. Gratis, rápidas y privadas por diseño.',
    lede:
      'Kelvo es una pequeña colección de herramientas web que hacen una sola cosa bien — generar una contraseña, comprimir una imagen, crear un código QR — sin registro, sin subir nada y sin rastreo.',
    sections: [
      {
        h: 'Por qué existe Kelvo',
        body: [
          'La mayoría de las herramientas “gratis” online esconden el costo real: suben tus archivos a un servidor, llenan la página de anuncios y rastreadores, o te obligan a crear una cuenta antes de poder hacer nada. Kelvo es lo contrario.',
          'Cada herramienta funciona <strong>enteramente en tu navegador</strong>, en tu propio dispositivo. Tus archivos nunca viajan a un servidor, porque no hay ningún servidor haciendo el trabajo.',
        ],
      },
      {
        h: 'Cómo está hecha',
        body: [
          'Kelvo es un sitio estático: sin backend, sin base de datos, sin analítica, sin cookies de rastreo. Por eso carga rápido y nos resulta imposible espiar lo que hacés. Las herramientas de imagen usan el Canvas del navegador; el generador de contraseñas usa Web Crypto: todo nativo, todo local.',
        ],
      },
      {
        h: 'Gratis, sin trucos',
        body: [
          'Cada herramienta es gratis, <strong>sin anuncios y sin nada que comprar</strong> — incluido el procesamiento por lotes y la descarga en ZIP de un clic. La mejor forma de apoyar el proyecto es simplemente compartirlo con alguien a quien le sirva.',
        ],
      },
      {
        h: 'Contacto',
        body: [
          '¿Dudas, ideas o encontraste un error? Escribí a <a href="mailto:' +
            mail +
            '">' +
            mail +
            '</a>: tus comentarios realmente moldean lo que se construye después.',
        ],
      },
    ],
    foot: 'Kelvo es un proyecto independiente.',
  },
}[locale];
---

<Layout title={C.title} description={C.desc} locale={locale} path={path} kind="about">
  <article class="legal">
    <h1>{C.title}</h1>
    <p class="lede">{C.lede}</p>
    {
      C.sections.map((s) => (
        <section>
          <h2>{s.h}</h2>
          {s.body.map((p) => (
            <p set:html={p} />
          ))}
        </section>
      ))
    }
    <p class="legal-foot">{C.foot}</p>
  </article>
</Layout>
