---
import { SITE, PRO, type Locale } from '@/config';
import { useTranslations } from '@/i18n/ui';
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return SITE.locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const path = `/${locale}/pro`;
const benefits = [t('pro.b1'), t('pro.b2'), t('pro.b3'), t('pro.b4')];
const canBuy = !!PRO.checkoutUrl;
---

<Layout title={t('pro.title')} description={t('pro.desc')} locale={locale} path={path} kind="pro">
  <section class="pro-hero">
    <span class="pro-badge">{t('pro.oneTime')}</span>
    <h1>{t('pro.h1')}</h1>
    <p class="lede">{t('pro.tagline')}</p>
  </section>

  <div class="pro-grid">
    <section class="panel" aria-labelledby="pro-benefits">
      <h2 id="pro-benefits" style="font-size:1.1rem">{t('pro.benefitsTitle')}</h2>
      <ul class="pro-benefits">
        {benefits.map((b) => (
          <li>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
            <span>{b}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="panel pro-buy" aria-labelledby="pro-price">
      <div class="pro-price" id="pro-price">{PRO.price}</div>
      <p class="muted" style="margin:0 0 16px">{t('pro.oneTime')}</p>
      {canBuy ? (
        <a class="btn block" href={PRO.checkoutUrl} rel="noopener">{t('pro.buy')}</a>
      ) : (
        <button class="btn block" type="button" disabled>{t('pro.comingSoon')}</button>
      )}
      <p class="privacy-note" style="justify-content:center;margin-top:14px">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {t('pro.privacyNote')}
      </p>
    </section>
  </div>

  <!-- License activation -->
  <section
    class="panel"
    id="pro-activate"
    aria-labelledby="pro-activate-title"
    data-activating={t('pro.activating')}
    data-activated={t('pro.activated')}
    data-invalid={t('pro.invalid')}
    data-network={t('pro.network')}
  >
    <h2 id="pro-activate-title" style="font-size:1.1rem">{t('pro.activateTitle')}</h2>
    <p class="muted">{t('pro.activateHint')}</p>
    <div class="result-field" style="max-width:520px">
      <input type="text" id="pro-key" autocomplete="off" spellcheck="false" placeholder={t('pro.licensePlaceholder')} aria-label={t('pro.licensePlaceholder')} />
      <button class="btn" id="pro-activate-btn" type="button">{t('pro.activate')}</button>
    </div>
    <p class="muted" id="pro-msg" role="status" aria-live="polite" style="margin:12px 0 0"></p>

    <!-- Shown when this device already has Pro -->
    <div id="pro-have" class="hidden" style="display:none">
      <p style="font-weight:600;color:var(--ok);margin:0 0 10px">{t('pro.alreadyPro')}</p>
      <button class="btn secondary" id="pro-remove" type="button">{t('pro.remove')}</button>
    </div>
  </section>
</Layout>

<style>
  .pro-hero { text-align: center; padding: 26px 0 6px; }
  .pro-badge {
    display: inline-block;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--accent-soft);
    border-radius: 999px;
    padding: 5px 12px;
    margin-bottom: 14px;
  }
  .pro-hero .lede { margin-left: auto; margin-right: auto; }
  .pro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    margin-top: 8px;
  }
  @media (min-width: 720px) {
    .pro-grid { grid-template-columns: 1.4fr 1fr; align-items: start; }
  }
  .pro-benefits { list-style: none; margin: 0; padding: 0; display: grid; gap: 12px; }
  .pro-benefits li { display: flex; gap: 10px; align-items: flex-start; }
  .pro-benefits svg { width: 20px; height: 20px; color: var(--ok); flex: none; margin-top: 2px; }
  .pro-buy { text-align: center; }
  .pro-price { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.03em; }
</style>

<script>
  import { isPro, activateLicense, deactivate } from '@/scripts/pro';

  const form = document.getElementById('pro-activate') as HTMLElement;
  const keyInput = document.getElementById('pro-key') as HTMLInputElement;
  const actBtn = document.getElementById('pro-activate-btn') as HTMLButtonElement;
  const msg = document.getElementById('pro-msg') as HTMLElement;
  const haveBox = document.getElementById('pro-have') as HTMLElement;
  const removeBtn = document.getElementById('pro-remove') as HTMLButtonElement;

  // Localized result strings, rendered server-side onto the section's dataset.
  const L = {
    activating: form.dataset.activating || 'Activating…',
    activated: form.dataset.activated || 'Activated',
    invalid: form.dataset.invalid || 'Invalid key',
    network: form.dataset.network || 'Network error',
  };

  function refresh() {
    const pro = isPro();
    haveBox.style.display = pro ? '' : 'none';
    haveBox.classList.toggle('hidden', !pro);
  }

  actBtn.addEventListener('click', async () => {
    const key = keyInput.value.trim();
    if (!key) return;
    actBtn.disabled = true;
    msg.style.color = 'var(--text-soft)';
    msg.textContent = L.activating;
    const res = await activateLicense(key);
    actBtn.disabled = false;
    if (res.ok) {
      msg.style.color = 'var(--ok)';
      msg.textContent = L.activated;
      keyInput.value = '';
      refresh();
    } else {
      msg.style.color = 'var(--danger)';
      msg.textContent = res.error === 'network' ? L.network : L.invalid;
    }
  });

  removeBtn?.addEventListener('click', () => {
    deactivate();
    msg.textContent = '';
    refresh();
  });

  refresh();
</script>
