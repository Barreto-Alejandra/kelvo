---
import { SITE, CONTACT, LEGAL_UPDATED, type Locale } from '@/config';
import Layout from '@/layouts/Layout.astro';

export function getStaticPaths() {
  return SITE.locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const path = `/${locale}/privacy`;
const mail = CONTACT.email;
const updated = LEGAL_UPDATED[locale];

const C = {
  en: {
    title: 'Privacy',
    desc:
      'Kelvo collects no personal data: no accounts, no tracking cookies, no analytics — and your files never leave your browser.',
    updatedLabel: 'Last updated',
    tldr:
      'The short version: we don’t collect your data. No accounts, no tracking cookies, no analytics — and your files never leave your browser.',
    sections: [
      {
        h: 'Your files and inputs stay on your device',
        body: [
          'Every tool — image compression, resizing, conversion, the password and QR generators — runs locally in your browser using your own device (Canvas and Web Crypto). Whatever you drop into a tool is <strong>never uploaded</strong> to us or to anyone else. We never receive it and never see it.',
        ],
      },
      {
        h: 'No tracking',
        body: [
          'We don’t use analytics, advertising, fingerprinting or third-party trackers, and we don’t set cookies to follow you around. There’s nothing on the page whose job is to watch you.',
        ],
      },
      {
        h: 'No accounts, nothing stored',
        body: [
          'There are no accounts and no login. Kelvo doesn’t use cookies or browser storage to track you, and nothing you do is saved on our side.',
        ],
      },
      {
        h: 'Hosting and server logs',
        body: [
          'The site is delivered as static files by our hosting provider. Like virtually any website, that provider may keep standard technical logs (such as IP addresses) for security and reliability. We don’t use these for tracking or profiling.',
        ],
      },
      {
        h: 'Changes and contact',
        body: [
          'We may update this page; the date above reflects the latest version. Questions about privacy? Email <a href="mailto:' +
            mail +
            '">' +
            mail +
            '</a>.',
        ],
      },
    ],
  },
  es: {
    title: 'Privacidad',
    desc:
      'Kelvo no recopila datos personales: sin cuentas, sin cookies de rastreo, sin analítica, y tus archivos nunca salen de tu navegador.',
    updatedLabel: 'Última actualización',
    tldr:
      'La versión corta: no recopilamos tus datos. Sin cuentas, sin cookies de rastreo, sin analítica, y tus archivos nunca salen de tu navegador.',
    sections: [
      {
        h: 'Tus archivos y datos se quedan en tu dispositivo',
        body: [
          'Cada herramienta — comprimir, redimensionar y convertir imágenes, los generadores de contraseñas y QR — funciona localmente en tu navegador usando tu propio dispositivo (Canvas y Web Crypto). Lo que sea que metas en una herramienta <strong>nunca se sube</strong> a nosotros ni a nadie. Nunca lo recibimos ni lo vemos.',
        ],
      },
      {
        h: 'Sin rastreo',
        body: [
          'No usamos analítica, publicidad, fingerprinting ni rastreadores de terceros, y no ponemos cookies para seguirte. No hay nada en la página cuyo trabajo sea vigilarte.',
        ],
      },
      {
        h: 'Sin cuentas, nada guardado',
        body: [
          'No hay cuentas ni inicio de sesión. Kelvo no usa cookies ni almacenamiento del navegador para rastrearte, y nada de lo que hacés se guarda de nuestro lado.',
        ],
      },
      {
        h: 'Hosting y registros del servidor',
        body: [
          'El sitio se entrega como archivos estáticos a través de nuestro proveedor de hosting. Como prácticamente cualquier sitio web, ese proveedor puede conservar registros técnicos estándar (como direcciones IP) por seguridad y fiabilidad. No los usamos para rastreo ni perfilado.',
        ],
      },
      {
        h: 'Cambios y contacto',
        body: [
          'Podemos actualizar esta página; la fecha de arriba refleja la última versión. ¿Dudas sobre privacidad? Escribí a <a href="mailto:' +
            mail +
            '">' +
            mail +
            '</a>.',
        ],
      },
    ],
  },
}[locale];
---

<Layout title={C.title} description={C.desc} locale={locale} path={path} kind="privacy">
  <article class="legal">
    <h1>{C.title}</h1>
    <p class="legal-meta">{C.updatedLabel}: {updated}</p>
    <p class="lede">{C.tldr}</p>
    {
      C.sections.map((s) => (
        <section>
          <h2>{s.h}</h2>
          {s.body.map((p) => (
            <p set:html={p} />
          ))}
        </section>
      ))
    }
  </article>
</Layout>
