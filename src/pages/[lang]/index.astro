---
import { SITE, ORIGIN, type Locale } from '@/config';
import { toolsByCategory } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';
import { withBase, toolPath } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import ToolCard from '@/components/ToolCard.astro';
import AdSlot from '@/components/AdSlot.astro';

export function getStaticPaths() {
  return SITE.locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const generators = toolsByCategory('generators');
const image = toolsByCategory('image');
const path = `/${locale}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: ORIGIN + withBase(path),
    inLanguage: locale,
    description: t('site.intro'),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    itemListElement: [...generators, ...image].map((tool, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: ORIGIN + withBase(toolPath(locale, tool)),
      name: tool.content[locale].name,
    })),
  },
];
---

<Layout
  title={t('site.tagline')}
  description={t('site.intro')}
  locale={locale}
  path={path}
  kind="home"
  jsonLd={jsonLd}
>
  <section style="padding:18px 0 8px">
    <h1>{t('home.heroTitle')}</h1>
    <p class="lede">{t('home.heroSubtitle')}</p>
    <div class="row" style="gap:8px;margin-top:14px">
      <span class="privacy-note" style="margin:0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {t('badge.private')}
      </span>
      <span class="privacy-note" style="margin:0">· {t('badge.free')}</span>
      <span class="privacy-note" style="margin:0">· {t('badge.noUpload')}</span>
    </div>
  </section>

  {/* Category filter — owns the active state; filters in place, no anchors, no scroll. */}
  <div class="catfilter" role="group" aria-label={t('tab.filterAria')}>
    <button type="button" class="seg is-active" data-cat="all" aria-pressed="true" tabindex="0">{t('tab.all')}</button>
    <button type="button" class="seg" data-cat="generators" aria-pressed="false" tabindex="-1">{t('tab.generators')}</button>
    <button type="button" class="seg" data-cat="image" aria-pressed="false" tabindex="-1">{t('tab.image')}</button>
  </div>
  <p class="sr-only" id="filter-status" role="status" aria-live="polite"></p>

  <div data-filter-root>
    <section id="generators" class="cat-section" data-cat="generators" aria-labelledby="gen-title">
      <div class="section-title">
        <h2 id="gen-title">{t('home.section.generators')}</h2>
      </div>
      <div class="grid">
        {generators.map((tool) => <ToolCard tool={tool} locale={locale} />)}
      </div>
    </section>

    <section id="image" class="cat-section" data-cat="image" aria-labelledby="img-title">
      <div class="section-title">
        <h2 id="img-title">{t('home.section.image')}</h2>
      </div>
      <div class="grid">
        {image.map((tool) => <ToolCard tool={tool} locale={locale} />)}
      </div>
    </section>
  </div>

  <AdSlot locale={locale} />

  <section class="panel" style="margin-top:30px">
    <h2>{t('home.privacyTitle')}</h2>
    <p class="muted" style="margin:0">{t('home.privacyBody')}</p>
  </section>
</Layout>

<script>
  // Category filter controller. The control is the single source of truth for the
  // active state (explicit selection — never inferred from scroll). Filtering is
  // CSS-driven via [data-filter]; all tool links stay in the DOM (SEO + no-JS).
  const group = document.querySelector('.catfilter');
  const root = document.querySelector('[data-filter-root]');
  const status = document.getElementById('filter-status');

  if (group && root) {
    const segs = [...group.querySelectorAll<HTMLButtonElement>('.seg')];
    const valid = ['all', 'generators', 'image'];
    const labelOf = (cat: string) =>
      segs.find((s) => s.dataset.cat === cat)?.textContent?.trim() ?? '';

    function apply(cat: string, focus: boolean) {
      if (!valid.includes(cat)) cat = 'all';
      root!.setAttribute('data-filter', cat);
      segs.forEach((s) => {
        const on = s.dataset.cat === cat;
        s.classList.toggle('is-active', on);
        s.setAttribute('aria-pressed', String(on));
        s.tabIndex = on ? 0 : -1;
      });
      // Persist as a non-id hash so the browser never tries to scroll to it.
      history.replaceState(
        null,
        '',
        cat === 'all' ? location.pathname + location.search : '#cat=' + cat,
      );
      if (status) {
        if (cat === 'all') {
          status.textContent = '';
        } else {
          const n = root!.querySelectorAll(
            '.cat-section[data-cat="' + cat + '"] .tool-card',
          ).length;
          status.textContent = n + ' · ' + labelOf(cat);
        }
      }
      if (focus) segs.find((s) => s.dataset.cat === cat)?.focus();
    }

    segs.forEach((s) => s.addEventListener('click', () => apply(s.dataset.cat || 'all', false)));

    // Roving arrow-key support for a real segmented-control feel.
    group.addEventListener('keydown', (e) => {
      const ke = e as KeyboardEvent;
      const i = segs.indexOf(document.activeElement as HTMLButtonElement);
      if (i < 0) return;
      let n = i;
      if (ke.key === 'ArrowRight' || ke.key === 'ArrowDown') n = (i + 1) % segs.length;
      else if (ke.key === 'ArrowLeft' || ke.key === 'ArrowUp') n = (i - 1 + segs.length) % segs.length;
      else if (ke.key === 'Home') n = 0;
      else if (ke.key === 'End') n = segs.length - 1;
      else return;
      ke.preventDefault();
      apply(segs[n].dataset.cat || 'all', true);
    });

    const readHash = () => (location.hash.match(/^#cat=(generators|image)$/) || [null, 'all'])[1] as string;
    apply(readHash(), false); // never scrolls
    window.addEventListener('hashchange', () => apply(readHash(), false));
  }
</script>
