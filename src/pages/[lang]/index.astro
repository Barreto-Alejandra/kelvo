---
import { SITE, ORIGIN, type Locale } from '@/config';
import { toolsByCategory } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';
import { withBase } from '@/i18n/utils';
import Layout from '@/layouts/Layout.astro';
import ToolCard from '@/components/ToolCard.astro';
import AdSlot from '@/components/AdSlot.astro';

export function getStaticPaths() {
  return SITE.locales.map((locale) => ({ params: { lang: locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
const t = useTranslations(locale);
const generators = toolsByCategory('generators');
const image = toolsByCategory('image');
const path = `/${locale}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE.name,
    url: ORIGIN + withBase(path),
    inLanguage: locale,
    description: t('site.intro'),
  },
];
---

<Layout
  title={t('site.tagline')}
  description={t('site.intro')}
  locale={locale}
  path={path}
  kind="home"
  jsonLd={jsonLd}
>
  <section style="padding:18px 0 8px">
    <h1>{t('home.heroTitle')}</h1>
    <p class="lede">{t('home.heroSubtitle')}</p>
    <div class="row" style="gap:8px;margin-top:14px">
      <span class="privacy-note" style="margin:0">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {t('badge.private')}
      </span>
      <span class="privacy-note" style="margin:0">· {t('badge.free')}</span>
      <span class="privacy-note" style="margin:0">· {t('badge.noUpload')}</span>
    </div>
  </section>

  <section id="generators" aria-labelledby="gen-title">
    <div class="section-title">
      <h2 id="gen-title">{t('home.section.generators')}</h2>
    </div>
    <div class="grid">
      {generators.map((tool) => <ToolCard tool={tool} locale={locale} />)}
    </div>
  </section>

  <section id="image" aria-labelledby="img-title">
    <div class="section-title">
      <h2 id="img-title">{t('home.section.image')}</h2>
    </div>
    <div class="grid">
      {image.map((tool) => <ToolCard tool={tool} locale={locale} />)}
    </div>
  </section>

  <AdSlot locale={locale} />

  <section class="panel" style="margin-top:30px">
    <h2>{t('home.privacyTitle')}</h2>
    <p class="muted" style="margin:0">{t('home.privacyBody')}</p>
  </section>
</Layout>

<script>
  // Scroll-spy: highlight the nav item for the section in view. Also activates
  // immediately on click, and treats "scrolled to the bottom" as the last
  // section being active (so short pages still light up the final item).
  const navLinks = new Map<string, HTMLAnchorElement>();
  document.querySelectorAll<HTMLAnchorElement>('.header-nav a[href*="#"]').forEach((a) => {
    const id = (a.getAttribute('href') || '').split('#')[1];
    if (id) navLinks.set(id, a);
  });
  const sections = [...navLinks.keys()]
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => !!el);

  if (sections.length) {
    const headerH = (document.querySelector('.site-header') as HTMLElement)?.offsetHeight || 60;
    const offset = headerH + 28;

    function setActive(id: string | null) {
      navLinks.forEach((a, key) => a.classList.toggle('active', key === id));
    }

    function onScroll() {
      const y = window.scrollY;
      let active: string | null = null;
      for (const s of sections) {
        if (s.offsetTop - offset <= y) active = s.id;
      }
      const atBottom = window.innerHeight + y >= document.documentElement.scrollHeight - 4;
      if (atBottom) active = sections[sections.length - 1].id;
      setActive(active);
    }

    let ticking = false;
    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          ticking = true;
          requestAnimationFrame(() => { onScroll(); ticking = false; });
        }
      },
      { passive: true },
    );
    window.addEventListener('resize', onScroll);
    navLinks.forEach((a, id) => a.addEventListener('click', () => setActive(id)));
    onScroll();
  }
</script>
