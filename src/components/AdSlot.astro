---
import { SITE, type Locale } from '@/config';
import { useTranslations } from '@/i18n/ui';

/**
 * Discreet ad slot. Renders a real AdSense unit only when ADSENSE_CLIENT is set
 * at build time. In dev (no client id) it shows a subtle placeholder so you can
 * see where ads will go. In production with no client id it renders nothing.
 */
interface Props {
  locale: Locale;
  slot?: string; // AdSense ad unit id
}
const { locale, slot } = Astro.props;
const t = useTranslations(locale);
const client = SITE.adsenseClient;
const isDev = import.meta.env.DEV;
---

{
  client ? (
    <aside class="ad-slot" aria-hidden="true">
      <div class="ad-label">{t('ad.label')}</div>
      <ins
        class="adsbygoogle"
        style="display:block"
        data-ad-client={client}
        data-ad-slot={slot}
        data-ad-format="auto"
        data-full-width-responsive="true"
      />
      <script is:inline>
        (adsbygoogle = window.adsbygoogle || []).push({});
      </script>
    </aside>
  ) : isDev ? (
    <aside
      class="ad-slot"
      aria-hidden="true"
      style="border:1px dashed var(--border);border-radius:var(--radius-sm);padding:18px;color:var(--text-faint)"
    >
      <div class="ad-label">{t('ad.label')}</div>
      <small>Ad placeholder — set ADSENSE_CLIENT to enable</small>
    </aside>
  ) : null
}
