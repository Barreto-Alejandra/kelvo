---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
const indexes = [0, 1, 2, 3, 4];
---

<div class="panel">
  <div class="row" style="margin-bottom:16px">
    <div style="flex:1;min-width:180px">
      <label for="pal-harmony">{L.harmony}</label>
      <select id="pal-harmony">
        <option value="random">{L.random}</option>
        <option value="analogous">{L.analogous}</option>
        <option value="monochromatic">{L.monochromatic}</option>
        <option value="complementary">{L.complementary}</option>
        <option value="triadic">{L.triadic}</option>
      </select>
    </div>
    <button class="btn" id="pal-gen" type="button" style="align-self:flex-end">{L.generate}</button>
  </div>

  <div class="swatches" id="pal">
    {
      indexes.map((i) => (
        <div class="swatch" data-i={i}>
          <div class="color" role="button" tabindex="0" title={L.copyHint} />
          <div class="bar">
            <span class="hex" />
            <button class="lockbtn" type="button" aria-label={L.lock} />
          </div>
        </div>
      ))
    }
  </div>
  <div class="privacy-note" style="margin-top:14px">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script define:vars={{ L }}>
  (() => {
    const LOCK_CLOSED = '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>';
    const LOCK_OPEN = '<rect x="5" y="11" width="14" height="9" rx="2"/><path d="M8 11V7a4 4 0 0 1 7.5-1.7"/>';
    const COUNT = 5;

    const colors = Array.from({ length: COUNT }, () => ({ hex: '#000000', locked: false }));
    const harmonyEl = document.getElementById('pal-harmony');
    const swatches = Array.from(document.querySelectorAll('#pal .swatch'));

    const rand = (min, max) => min + Math.random() * (max - min);
    const wrap = (h) => ((h % 360) + 360) % 360;

    function hslToHex(h, s, l) {
      s /= 100; l /= 100;
      const k = (n) => (n + h / 30) % 12;
      const a = s * Math.min(l, 1 - l);
      const f = (n) => {
        const c = l - a * Math.max(-1, Math.min(k(n) - 3, Math.min(9 - k(n), 1)));
        return Math.round(255 * c).toString(16).padStart(2, '0');
      };
      return `#${f(0)}${f(8)}${f(4)}`;
    }

    function paletteHSL(mode) {
      const base = rand(0, 360);
      const out = [];
      for (let i = 0; i < COUNT; i++) {
        let h, s, l;
        switch (mode) {
          case 'analogous':
            h = wrap(base + (i - 2) * 28); s = rand(60, 78); l = rand(45, 68); break;
          case 'monochromatic':
            h = base; s = rand(45, 70); l = 24 + i * 13; break;
          case 'complementary':
            h = wrap(base + (i < 3 ? 0 : 180) + rand(-12, 12)); s = rand(55, 78); l = rand(40, 70); break;
          case 'triadic':
            h = wrap(base + (i % 3) * 120 + rand(-10, 10)); s = rand(58, 78); l = rand(42, 68); break;
          default: // random
            h = rand(0, 360); s = rand(55, 82); l = rand(42, 66);
        }
        out.push(hslToHex(h, s, l));
      }
      return out;
    }

    function render() {
      swatches.forEach((sw, i) => {
        const c = colors[i];
        sw.querySelector('.color').style.background = c.hex;
        const hexEl = sw.querySelector('.hex');
        hexEl.textContent = c.hex.toUpperCase();
        const btn = sw.querySelector('.lockbtn');
        btn.innerHTML = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${c.locked ? LOCK_CLOSED : LOCK_OPEN}</svg>`;
        btn.setAttribute('aria-label', c.locked ? L.unlock : L.lock);
        btn.style.color = c.locked ? 'var(--accent)' : 'var(--text-soft)';
      });
    }

    function generate() {
      const next = paletteHSL(harmonyEl.value);
      for (let i = 0; i < COUNT; i++) if (!colors[i].locked) colors[i].hex = next[i];
      render();
    }

    swatches.forEach((sw, i) => {
      sw.querySelector('.color').addEventListener('click', () => window.copyText(colors[i].hex.toUpperCase()));
      sw.querySelector('.color').addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); window.copyText(colors[i].hex.toUpperCase()); }
      });
      sw.querySelector('.lockbtn').addEventListener('click', () => { colors[i].locked = !colors[i].locked; render(); });
    });

    document.getElementById('pal-gen').addEventListener('click', generate);
    harmonyEl.addEventListener('change', generate);
    document.addEventListener('keydown', (e) => {
      const tag = (e.target.tagName || '').toLowerCase();
      if (e.code === 'Space' && tag !== 'input' && tag !== 'select' && tag !== 'textarea') {
        e.preventDefault();
        generate();
      }
    });

    generate();
  })();
</script>
