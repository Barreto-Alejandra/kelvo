---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';
import { homePath } from '@/i18n/utils';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
const proPath = `${homePath(locale)}/pro`;
---

<div class="panel">
  <div class="dropzone" id="cz-drop" role="button" tabindex="0" aria-label={t('common.dropHere')}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M8 8l4-4 4 4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
    <p><strong>{t('common.dropHere')}</strong></p>
    <p class="muted">{t('common.dropHint')}</p>
    <input type="file" id="cz-input" accept="image/*" multiple class="hidden" />
  </div>

  <div id="cz-work" class="hidden">
    <div style="text-align:center;margin-bottom:18px">
      <img id="cz-preview" class="preview-img" alt={t('common.imagePreview')} />
    </div>

    <div class="row" style="margin-bottom:16px">
      <div style="min-width:150px">
        <label for="cz-fmt">{L.outputFormat}</label>
        <select id="cz-fmt">
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
      <div style="flex:1;min-width:180px">
        <label for="cz-q">{L.quality}: <span id="cz-qv" style="color:var(--accent)">70</span>%</label>
        <input type="range" id="cz-q" min="10" max="100" step="1" value="70" />
      </div>
    </div>

    <div class="stats" style="margin-bottom:18px">
      <div class="stat"><div class="k">{L.original}</div><div class="v" id="cz-orig">—</div></div>
      <div class="stat"><div class="k">{L.compressed}</div><div class="v" id="cz-comp">—</div></div>
      <div class="stat"><div class="k">{L.saved}</div><div class="v" id="cz-saved" style="color:var(--ok)">—</div></div>
    </div>

    <div class="row">
      <button class="btn" id="cz-dl" type="button">{t('common.download')}</button>
      <button class="btn secondary" id="cz-reset" type="button">{L.chooseAnother}</button>
    </div>
  </div>

  <!-- Free tier: dropped many → gentle upsell (still loads the first image above) -->
  <div id="cz-upsell" class="upsell hidden" data-selected={t('batch.selectedN')}>
    <span class="badge-pro">PRO</span>
    <p class="upsell-title">{t('batch.upsellTitle')}</p>
    <p><strong id="cz-upsell-n"></strong> {t('batch.upsellBody')}</p>
    <p class="muted">{t('batch.upsellShowingOne')}</p>
    <a class="btn" href={proPath}>{t('pro.buy')}</a>
  </div>

  <!-- Pro: batch mode -->
  <div
    id="cz-batch"
    class="batch hidden"
    data-processing={t('batch.processing')}
    data-done={t('batch.done')}
    data-some-failed={t('batch.someFailed')}
    data-too-many={t('batch.tooMany')}
  >
    <div class="batch-head">
      <span class="badge-pro">PRO</span>
      <strong><span id="cz-batch-n">0</span> {t('batch.ready')}</strong>
    </div>

    <div class="row" style="margin:14px 0">
      <div style="min-width:150px">
        <label for="cz-bfmt">{L.outputFormat}</label>
        <select id="cz-bfmt">
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
      <div style="flex:1;min-width:180px">
        <label for="cz-bq">{L.quality}: <span id="cz-bqv" style="color:var(--accent)">70</span>%</label>
        <input type="range" id="cz-bq" min="10" max="100" step="1" value="70" />
      </div>
    </div>

    <ul id="cz-batch-list" class="batch-list"></ul>
    <p id="cz-batch-status" class="muted" role="status" aria-live="polite" style="margin:12px 0 0"></p>

    <div class="row" style="margin-top:14px">
      <button class="btn" id="cz-batch-dl" type="button">{t('batch.downloadZip')}</button>
      <button class="btn secondary" id="cz-batch-reset" type="button">{t('batch.startOver')}</button>
    </div>
  </div>

  <div class="privacy-note" style="margin-top:14px">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script>
  import {
    setupDropzone, loadImage, formatBytes, renderCanvas, canvasToBlob, triggerDownload,
    baseName, EXT, type LoadedImage,
  } from '@/scripts/image-utils';
  import { isPro } from '@/scripts/pro';
  import { processToZip, MAX_BATCH } from '@/scripts/batch';

  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const drop = $('cz-drop');
  const input = $('cz-input') as HTMLInputElement;
  const work = $('cz-work');
  const preview = $('cz-preview') as HTMLImageElement;
  const fmt = $('cz-fmt') as HTMLSelectElement;
  const q = $('cz-q') as HTMLInputElement;
  const qv = $('cz-qv');
  const origEl = $('cz-orig');
  const compEl = $('cz-comp');
  const savedEl = $('cz-saved');

  const upsell = $('cz-upsell');
  const upsellN = $('cz-upsell-n');
  const batch = $('cz-batch');
  const batchN = $('cz-batch-n');
  const bfmt = $('cz-bfmt') as HTMLSelectElement;
  const bq = $('cz-bq') as HTMLInputElement;
  const bqv = $('cz-bqv');
  const batchList = $('cz-batch-list');
  const batchStatus = $('cz-batch-status');
  const batchDl = $('cz-batch-dl') as HTMLButtonElement;

  let current: LoadedImage | null = null;
  let outBlob: Blob | null = null;
  let outUrl = '';
  let batchFiles: File[] = [];

  async function recompress() {
    if (!current) return;
    try {
      const canvas = renderCanvas(current.img, current.img.naturalWidth, current.img.naturalHeight, '#ffffff');
      const blob = await canvasToBlob(canvas, fmt.value, parseInt(q.value, 10) / 100);
      if (outUrl) URL.revokeObjectURL(outUrl);
      outBlob = blob;
      outUrl = URL.createObjectURL(blob);
      compEl.textContent = formatBytes(blob.size);
      const pct = Math.round((1 - blob.size / current.file.size) * 100);
      savedEl.textContent = pct > 0 ? `${pct}%` : '0%';
      savedEl.style.color = pct > 0 ? 'var(--ok)' : 'var(--warn)';
    } catch {
      (window as any).showToast?.(document.body.dataset.error || '');
    }
  }

  // Debounce while dragging the quality slider so we don't re-encode on every pixel.
  let recompressTimer: number | undefined;
  function recompressSoon() {
    window.clearTimeout(recompressTimer);
    recompressTimer = window.setTimeout(recompress, 130);
  }

  function loadSingle(data: LoadedImage) {
    current = data;
    preview.src = data.url;
    origEl.textContent = formatBytes(data.file.size);
    work.classList.remove('hidden');
    recompress();
  }

  setupDropzone(
    drop, input,
    (data) => { drop.classList.add('hidden'); loadSingle(data); },
    (files) => { isPro() ? startBatch(files) : showUpsell(files); },
  );

  function showUpsell(files: File[]) {
    upsellN.textContent = (upsell.dataset.selected || '').replace('%n', String(files.length));
    drop.classList.add('hidden');
    upsell.classList.remove('hidden');
    loadImage(files[0]).then(loadSingle).catch(() => {});
  }

  function startBatch(files: File[]) {
    batchFiles = files.slice(0, MAX_BATCH);
    batchN.textContent = String(batchFiles.length);
    batchList.innerHTML = '';
    for (const f of batchFiles) {
      const li = document.createElement('li');
      const nm = document.createElement('span'); nm.className = 'bl-name'; nm.textContent = f.name;
      const sz = document.createElement('span'); sz.className = 'bl-size'; sz.textContent = formatBytes(f.size);
      li.append(nm, sz);
      batchList.appendChild(li);
    }
    batchStatus.textContent = files.length > MAX_BATCH ? (batch.dataset.tooMany || '') : '';
    drop.classList.add('hidden');
    work.classList.add('hidden');
    batch.classList.remove('hidden');
  }

  q.addEventListener('input', () => { qv.textContent = q.value; recompressSoon(); });
  fmt.addEventListener('change', recompress);
  bq.addEventListener('input', () => { bqv.textContent = bq.value; });

  $('cz-dl').addEventListener('click', () => {
    if (!outBlob || !current) return;
    triggerDownload(outUrl, `${baseName(current.file.name)}-compressed.${EXT[fmt.value]}`);
  });

  batchDl.addEventListener('click', async () => {
    if (!batchFiles.length) return;
    batchDl.disabled = true;
    const type = bfmt.value;
    const quality = parseInt(bq.value, 10) / 100;
    const total = batchFiles.length;
    const procLabel = batch.dataset.processing || 'Processing';
    const res = await processToZip(
      batchFiles,
      async (file) => {
        const { img, url } = await loadImage(file);
        try {
          const canvas = renderCanvas(img, img.naturalWidth, img.naturalHeight, '#ffffff');
          const blob = await canvasToBlob(canvas, type, quality);
          return { name: `${baseName(file.name)}-compressed.${EXT[type]}`, blob };
        } finally {
          URL.revokeObjectURL(url);
        }
      },
      'kelvo-compressed.zip',
      (done) => { batchStatus.textContent = `${procLabel}… ${done}/${total}`; },
    );
    batchDl.disabled = false;
    batchStatus.textContent =
      (batch.dataset.done || '') + (res.failed > 0 ? ` — ${batch.dataset.someFailed || ''}` : '');
    (window as any).showToast?.(batch.dataset.done || '');
  });

  function resetAll() {
    if (current) URL.revokeObjectURL(current.url);
    if (outUrl) URL.revokeObjectURL(outUrl);
    current = null; outBlob = null; outUrl = ''; batchFiles = [];
    input.value = '';
    work.classList.add('hidden');
    upsell.classList.add('hidden');
    batch.classList.add('hidden');
    batchStatus.textContent = '';
    drop.classList.remove('hidden');
  }

  $('cz-reset').addEventListener('click', resetAll);
  $('cz-batch-reset').addEventListener('click', resetAll);
</script>
