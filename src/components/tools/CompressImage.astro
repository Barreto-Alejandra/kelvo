---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
---

<div class="panel">
  <div class="dropzone" id="cz-drop" role="button" tabindex="0" aria-label={t('common.dropHere')}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M8 8l4-4 4 4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
    <p><strong>{t('common.dropHere')}</strong></p>
    <p class="muted">{t('common.dropHint')}</p>
    <input type="file" id="cz-input" accept="image/*" class="hidden" />
  </div>

  <div id="cz-work" class="hidden">
    <div style="text-align:center;margin-bottom:18px">
      <img id="cz-preview" class="preview-img" alt={t('common.imagePreview')} />
    </div>

    <div class="row" style="margin-bottom:16px">
      <div style="min-width:150px">
        <label for="cz-fmt">{L.outputFormat}</label>
        <select id="cz-fmt">
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
      <div style="flex:1;min-width:180px">
        <label for="cz-q">{L.quality}: <span id="cz-qv" style="color:var(--accent)">70</span>%</label>
        <input type="range" id="cz-q" min="10" max="100" step="1" value="70" />
      </div>
    </div>

    <div class="stats" style="margin-bottom:18px">
      <div class="stat"><div class="k">{L.original}</div><div class="v" id="cz-orig">—</div></div>
      <div class="stat"><div class="k">{L.compressed}</div><div class="v" id="cz-comp">—</div></div>
      <div class="stat"><div class="k">{L.saved}</div><div class="v" id="cz-saved" style="color:var(--ok)">—</div></div>
    </div>

    <div class="row">
      <button class="btn" id="cz-dl" type="button">{t('common.download')}</button>
      <button class="btn secondary" id="cz-reset" type="button">{L.chooseAnother}</button>
    </div>
  </div>

  <div class="privacy-note" style="margin-top:14px">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script>
  import {
    setupDropzone, formatBytes, renderCanvas, canvasToBlob, triggerDownload,
    baseName, EXT, type LoadedImage,
  } from '@/scripts/image-utils';

  const drop = document.getElementById('cz-drop') as HTMLElement;
  const input = document.getElementById('cz-input') as HTMLInputElement;
  const work = document.getElementById('cz-work') as HTMLElement;
  const preview = document.getElementById('cz-preview') as HTMLImageElement;
  const fmt = document.getElementById('cz-fmt') as HTMLSelectElement;
  const q = document.getElementById('cz-q') as HTMLInputElement;
  const qv = document.getElementById('cz-qv') as HTMLElement;
  const origEl = document.getElementById('cz-orig') as HTMLElement;
  const compEl = document.getElementById('cz-comp') as HTMLElement;
  const savedEl = document.getElementById('cz-saved') as HTMLElement;

  let current: LoadedImage | null = null;
  let outBlob: Blob | null = null;
  let outUrl = '';

  async function recompress() {
    if (!current) return;
    try {
      const canvas = renderCanvas(current.img, current.img.naturalWidth, current.img.naturalHeight, '#ffffff');
      const blob = await canvasToBlob(canvas, fmt.value, parseInt(q.value, 10) / 100);
      if (outUrl) URL.revokeObjectURL(outUrl);
      outBlob = blob;
      outUrl = URL.createObjectURL(blob);
      compEl.textContent = formatBytes(blob.size);
      const pct = Math.round((1 - blob.size / current.file.size) * 100);
      savedEl.textContent = pct > 0 ? `${pct}%` : '0%';
      savedEl.style.color = pct > 0 ? 'var(--ok)' : 'var(--warn)';
    } catch {
      (window as any).showToast?.(document.body.dataset.error || '');
    }
  }

  // Debounce while dragging the quality slider so we don't re-encode on every pixel.
  let recompressTimer: number | undefined;
  function recompressSoon() {
    window.clearTimeout(recompressTimer);
    recompressTimer = window.setTimeout(recompress, 130);
  }

  setupDropzone(drop, input, (data) => {
    current = data;
    preview.src = data.url;
    origEl.textContent = formatBytes(data.file.size);
    drop.classList.add('hidden');
    work.classList.remove('hidden');
    recompress();
  });

  q.addEventListener('input', () => { qv.textContent = q.value; recompressSoon(); });
  fmt.addEventListener('change', recompress);

  document.getElementById('cz-dl')!.addEventListener('click', () => {
    if (!outBlob || !current) return;
    triggerDownload(outUrl, `${baseName(current.file.name)}-compressed.${EXT[fmt.value]}`);
  });

  document.getElementById('cz-reset')!.addEventListener('click', () => {
    if (current) URL.revokeObjectURL(current.url);
    if (outUrl) URL.revokeObjectURL(outUrl);
    current = null; outBlob = null; outUrl = '';
    input.value = '';
    work.classList.add('hidden');
    drop.classList.remove('hidden');
  });
</script>
