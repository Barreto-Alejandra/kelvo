---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
---

<div class="panel">
  <div class="result-field">
    <div class="out" id="pw-out" data-copy=""></div>
    <button class="btn secondary" id="pw-copy" type="button" aria-label={t('common.copy')}>
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
    </button>
  </div>
  <div class="meter"><span id="pw-meter"></span></div>
  <div class="muted" id="pw-strength" style="margin-top:6px" aria-live="polite"></div>

  <div class="field" style="margin-top:18px">
    <label for="pw-len">{L.length}: <span id="pw-len-val" style="color:var(--accent)"></span></label>
    <input type="range" id="pw-len" min="6" max="48" value="18" />
  </div>

  <div class="checks">
    <label class="check"><input type="checkbox" id="pw-upper" checked /> {L.uppercase}</label>
    <label class="check"><input type="checkbox" id="pw-lower" checked /> {L.lowercase}</label>
    <label class="check"><input type="checkbox" id="pw-num" checked /> {L.numbers}</label>
    <label class="check"><input type="checkbox" id="pw-sym" checked /> {L.symbols}</label>
    <label class="check"><input type="checkbox" id="pw-amb" /> {L.excludeAmbiguous}</label>
  </div>

  <button class="btn block" id="pw-gen" type="button" style="margin-top:18px">{L.generate}</button>
  <div class="privacy-note">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script define:vars={{ L }}>
  (() => {
    const SETS = {
      upper: 'ABCDEFGHIJKLMNOPQRSTUVWXYZ',
      lower: 'abcdefghijklmnopqrstuvwxyz',
      num: '0123456789',
      sym: '!@#$%^&*()-_=+[]{};:,.?/',
    };
    const AMBIGUOUS = /[Il1O0o]/g;

    const $ = (id) => document.getElementById(id);
    const out = $('pw-out');
    const meter = $('pw-meter');
    const strengthLabel = $('pw-strength');
    const lenInput = $('pw-len');
    const lenVal = $('pw-len-val');

    // Cryptographically secure random integer in [0, max) without modulo bias.
    function randInt(max) {
      const limit = Math.floor(0xffffffff / max) * max;
      const buf = new Uint32Array(1);
      let x;
      do {
        crypto.getRandomValues(buf);
        x = buf[0];
      } while (x >= limit);
      return x % max;
    }

    function pick(str) {
      return str[randInt(str.length)];
    }

    function shuffle(arr) {
      for (let i = arr.length - 1; i > 0; i--) {
        const j = randInt(i + 1);
        [arr[i], arr[j]] = [arr[j], arr[i]];
      }
      return arr;
    }

    function activeSets() {
      const sets = [];
      if ($('pw-upper').checked) sets.push(SETS.upper);
      if ($('pw-lower').checked) sets.push(SETS.lower);
      if ($('pw-num').checked) sets.push(SETS.num);
      if ($('pw-sym').checked) sets.push(SETS.sym);
      if ($('pw-amb').checked) return sets.map((s) => s.replace(AMBIGUOUS, ''));
      return sets;
    }

    function strengthOf(pw, poolSize) {
      const bits = pw.length * Math.log2(Math.max(poolSize, 2));
      let label = L.weak, color = 'var(--danger)';
      if (bits >= 80) { label = L.strong; color = 'var(--ok)'; }
      else if (bits >= 60) { label = L.good; color = '#3b82f6'; }
      else if (bits >= 40) { label = L.fair; color = 'var(--warn)'; }
      const pct = Math.min(100, Math.round((bits / 110) * 100));
      return { label, color, pct };
    }

    const copyBtn = $('pw-copy');

    function generate() {
      const sets = activeSets();
      if (sets.length === 0) {
        out.textContent = L.atLeastOne;
        out.dataset.copy = '';
        meter.style.width = '0';
        strengthLabel.textContent = '';
        copyBtn.disabled = true;
        return;
      }
      copyBtn.disabled = false;
      const len = parseInt(lenInput.value, 10);
      const pool = sets.join('');
      const chars = [];
      // Guarantee at least one char from each chosen set.
      for (const s of sets) chars.push(pick(s));
      while (chars.length < len) chars.push(pick(pool));
      const pw = shuffle(chars).slice(0, len).join('');

      out.textContent = pw;
      out.dataset.copy = pw;
      const s = strengthOf(pw, pool.length);
      meter.style.width = s.pct + '%';
      meter.style.background = s.color;
      strengthLabel.innerHTML = `${L.strength}: <strong style="color:${s.color}">${s.label}</strong>`;
    }

    lenInput.addEventListener('input', () => { lenVal.textContent = lenInput.value; generate(); });
    document.querySelectorAll('.checks input').forEach((c) => c.addEventListener('change', generate));
    $('pw-gen').addEventListener('click', generate);
    $('pw-copy').addEventListener('click', () => {
      if (out.dataset.copy) window.copyText(out.dataset.copy);
    });

    lenVal.textContent = lenInput.value;
    generate();
  })();
</script>
