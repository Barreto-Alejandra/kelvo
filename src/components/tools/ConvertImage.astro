---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
---

<div class="panel">
  <div class="dropzone" id="cv-drop" role="button" tabindex="0" aria-label={t('common.dropHere')}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M8 8l4-4 4 4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
    <p><strong>{t('common.dropHere')}</strong></p>
    <p class="muted">{t('common.dropHint')}</p>
    <p class="muted">{t('batch.multiHint')}</p>
    <input type="file" id="cv-input" accept="image/*" multiple class="hidden" />
  </div>

  <div id="cv-work" class="hidden">
    <div style="text-align:center;margin-bottom:18px">
      <img id="cv-preview" class="preview-img" alt={t('common.imagePreview')} />
    </div>

    <div class="row" style="margin-bottom:16px">
      <div style="min-width:150px">
        <label for="cv-fmt">{L.convertTo}</label>
        <select id="cv-fmt">
          <option value="image/png">PNG</option>
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
      <div style="flex:1;min-width:180px" id="cv-qwrap">
        <label for="cv-q">{L.quality}: <span id="cv-qv" style="color:var(--accent)">92</span>%</label>
        <input type="range" id="cv-q" min="10" max="100" step="1" value="92" />
      </div>
    </div>

    <div class="row">
      <button class="btn" id="cv-dl" type="button">{t('common.download')}</button>
      <button class="btn secondary" id="cv-reset" type="button">{L.chooseAnother}</button>
    </div>
  </div>

  <!-- Batch mode (free): drop several images, download one ZIP -->
  <div
    id="cv-batch"
    class="batch hidden"
    data-processing={t('batch.processing')}
    data-done={t('batch.done')}
    data-some-failed={t('batch.someFailed')}
    data-too-many={t('batch.tooMany')}
  >
    <div class="batch-head">
      <strong><span id="cv-batch-n">0</span> {t('batch.ready')}</strong>
    </div>

    <div class="row" style="margin:14px 0">
      <div style="min-width:150px">
        <label for="cv-bfmt">{L.convertTo}</label>
        <select id="cv-bfmt">
          <option value="image/png">PNG</option>
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
      <div style="flex:1;min-width:180px" id="cv-bqwrap">
        <label for="cv-bq">{L.quality}: <span id="cv-bqv" style="color:var(--accent)">92</span>%</label>
        <input type="range" id="cv-bq" min="10" max="100" step="1" value="92" />
      </div>
    </div>

    <ul id="cv-batch-list" class="batch-list"></ul>
    <p id="cv-batch-status" class="muted" role="status" aria-live="polite" style="margin:12px 0 0"></p>

    <div class="row" style="margin-top:14px">
      <button class="btn" id="cv-batch-dl" type="button">{t('batch.downloadZip')}</button>
      <button class="btn secondary" id="cv-batch-reset" type="button">{t('batch.startOver')}</button>
    </div>
  </div>

  <div class="privacy-note" style="margin-top:14px">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script>
  import {
    setupDropzone, loadImage, renderCanvas, canvasToBlob, triggerDownload,
    baseName, EXT, type LoadedImage,
  } from '@/scripts/image-utils';
  import { processToZip, MAX_BATCH } from '@/scripts/batch';

  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const drop = $('cv-drop');
  const input = $('cv-input') as HTMLInputElement;
  const work = $('cv-work');
  const preview = $('cv-preview') as HTMLImageElement;
  const fmt = $('cv-fmt') as HTMLSelectElement;
  const q = $('cv-q') as HTMLInputElement;
  const qv = $('cv-qv');
  const qwrap = $('cv-qwrap');

  const batch = $('cv-batch');
  const batchN = $('cv-batch-n');
  const bfmt = $('cv-bfmt') as HTMLSelectElement;
  const bq = $('cv-bq') as HTMLInputElement;
  const bqv = $('cv-bqv');
  const bqwrap = $('cv-bqwrap');
  const batchList = $('cv-batch-list');
  const batchStatus = $('cv-batch-status');
  const batchDl = $('cv-batch-dl') as HTMLButtonElement;

  let current: LoadedImage | null = null;
  let batchFiles: File[] = [];

  function syncQuality() {
    qwrap.style.display = fmt.value === 'image/png' ? 'none' : '';
  }
  function syncBatchQuality() {
    bqwrap.style.display = bfmt.value === 'image/png' ? 'none' : '';
  }

  function encodeOne(img: HTMLImageElement, type: string, quality: number): Promise<Blob> {
    const bg = type === 'image/jpeg' ? '#ffffff' : undefined;
    const canvas = renderCanvas(img, img.naturalWidth, img.naturalHeight, bg);
    return canvasToBlob(canvas, type, quality);
  }

  function loadSingle(data: LoadedImage) {
    current = data;
    preview.src = data.url;
    work.classList.remove('hidden');
    syncQuality();
  }

  setupDropzone(
    drop, input,
    (data) => { drop.classList.add('hidden'); loadSingle(data); },
    (files) => startBatch(files),
  );

  function startBatch(files: File[]) {
    batchFiles = files.slice(0, MAX_BATCH);
    batchN.textContent = String(batchFiles.length);
    batchList.innerHTML = '';
    for (const f of batchFiles) {
      const li = document.createElement('li');
      const nm = document.createElement('span'); nm.className = 'bl-name'; nm.textContent = f.name;
      const sz = document.createElement('span'); sz.className = 'bl-size'; sz.textContent = `${(f.size / 1024).toFixed(0)} KB`;
      li.append(nm, sz);
      batchList.appendChild(li);
    }
    batchStatus.textContent = files.length > MAX_BATCH ? (batch.dataset.tooMany || '') : '';
    syncBatchQuality();
    drop.classList.add('hidden');
    work.classList.add('hidden');
    batch.classList.remove('hidden');
  }

  fmt.addEventListener('change', syncQuality);
  q.addEventListener('input', () => (qv.textContent = q.value));
  bfmt.addEventListener('change', syncBatchQuality);
  bq.addEventListener('input', () => (bqv.textContent = bq.value));

  const cvDl = $('cv-dl') as HTMLButtonElement;
  cvDl.addEventListener('click', async () => {
    if (!current) return;
    const type = fmt.value;
    let url = '';
    cvDl.disabled = true;
    try {
      const blob = await encodeOne(current.img, type, parseInt(q.value, 10) / 100);
      url = URL.createObjectURL(blob);
      triggerDownload(url, `${baseName(current.file.name)}-converted.${EXT[type]}`);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch {
      if (url) URL.revokeObjectURL(url);
      (window as any).showToast?.(document.body.dataset.error || '');
    } finally {
      cvDl.disabled = false;
    }
  });

  batchDl.addEventListener('click', async () => {
    if (!batchFiles.length) return;
    batchDl.disabled = true;
    const type = bfmt.value;
    const quality = parseInt(bq.value, 10) / 100;
    const total = batchFiles.length;
    const procLabel = batch.dataset.processing || 'Processing';
    const res = await processToZip(
      batchFiles,
      async (file) => {
        const { img, url } = await loadImage(file);
        try {
          const blob = await encodeOne(img, type, quality);
          return { name: `${baseName(file.name)}-converted.${EXT[type]}`, blob };
        } finally {
          URL.revokeObjectURL(url);
        }
      },
      'kelvo-converted.zip',
      (done) => { batchStatus.textContent = `${procLabel}… ${done}/${total}`; },
    );
    batchDl.disabled = false;
    batchStatus.textContent =
      (batch.dataset.done || '') + (res.failed > 0 ? ` — ${batch.dataset.someFailed || ''}` : '');
    (window as any).showToast?.(batch.dataset.done || '');
  });

  function resetAll() {
    if (current) URL.revokeObjectURL(current.url);
    current = null; batchFiles = [];
    input.value = '';
    work.classList.add('hidden');
    batch.classList.add('hidden');
    batchStatus.textContent = '';
    drop.classList.remove('hidden');
  }

  $('cv-reset').addEventListener('click', resetAll);
  $('cv-batch-reset').addEventListener('click', resetAll);
</script>
