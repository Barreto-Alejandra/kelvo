---
import type { Locale } from '@/config';
import type { Tool } from '@/i18n/tools';
import { useTranslations } from '@/i18n/ui';

interface Props {
  tool: Tool;
  locale: Locale;
}
const { tool, locale } = Astro.props;
const L = tool.content[locale].ui;
const t = useTranslations(locale);
---

<div class="panel">
  <div class="dropzone" id="rz-drop" role="button" tabindex="0" aria-label={t('common.dropHere')}>
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 16V4M8 8l4-4 4 4"/><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2"/></svg>
    <p><strong>{t('common.dropHere')}</strong></p>
    <p class="muted">{t('common.dropHint')}</p>
    <p class="muted">{t('batch.multiHint')}</p>
    <input type="file" id="rz-input" accept="image/*" multiple class="hidden" />
  </div>

  <div id="rz-work" class="hidden">
    <div style="text-align:center;margin-bottom:18px">
      <img id="rz-preview" class="preview-img" alt={t('common.imagePreview')} />
    </div>

    <div class="row" style="margin-bottom:12px">
      <div style="flex:1;min-width:120px">
        <label for="rz-w">{L.width}</label>
        <input type="number" id="rz-w" min="1" max="10000" step="1" />
      </div>
      <div style="flex:1;min-width:120px">
        <label for="rz-h">{L.height}</label>
        <input type="number" id="rz-h" min="1" max="10000" step="1" />
      </div>
      <div style="min-width:150px">
        <label for="rz-fmt">{L.outputFormat}</label>
        <select id="rz-fmt">
          <option value="keep">{L.keepOriginal}</option>
          <option value="image/png">PNG</option>
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
    </div>

    <label class="check" style="margin-bottom:18px">
      <input type="checkbox" id="rz-lock" checked /> {L.lockRatio}
    </label>

    <div class="row">
      <button class="btn" id="rz-dl" type="button">{t('common.download')}</button>
      <button class="btn secondary" id="rz-reset" type="button">{L.chooseAnother}</button>
    </div>
  </div>

  <!-- Batch mode (free): resize all to a target width (height auto), download one ZIP -->
  <div
    id="rz-batch"
    class="batch hidden"
    data-processing={t('batch.processing')}
    data-done={t('batch.done')}
    data-some-failed={t('batch.someFailed')}
    data-too-many={t('batch.tooMany')}
  >
    <div class="batch-head">
      <strong><span id="rz-batch-n">0</span> {t('batch.ready')}</strong>
    </div>

    <div class="row" style="margin:14px 0 6px">
      <div style="flex:1;min-width:140px">
        <label for="rz-bw">{t('batch.resizeWidth')}</label>
        <input type="number" id="rz-bw" min="1" max="10000" step="1" value="1280" />
      </div>
      <div style="min-width:150px">
        <label for="rz-bfmt">{L.outputFormat}</label>
        <select id="rz-bfmt">
          <option value="keep">{L.keepOriginal}</option>
          <option value="image/png">PNG</option>
          <option value="image/jpeg">JPG</option>
          <option value="image/webp">WebP</option>
        </select>
      </div>
    </div>
    <p class="muted" style="margin:0 0 6px">{t('batch.resizeWidthHint')}</p>

    <ul id="rz-batch-list" class="batch-list"></ul>
    <p id="rz-batch-status" class="muted" role="status" aria-live="polite" style="margin:12px 0 0"></p>

    <div class="row" style="margin-top:14px">
      <button class="btn" id="rz-batch-dl" type="button">{t('batch.downloadZip')}</button>
      <button class="btn secondary" id="rz-batch-reset" type="button">{t('batch.startOver')}</button>
    </div>
  </div>

  <div class="privacy-note" style="margin-top:14px">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
    {t('common.processedLocally')}
  </div>
</div>

<script>
  import {
    setupDropzone, loadImage, renderCanvas, canvasToBlob, triggerDownload,
    baseName, EXT, type LoadedImage,
  } from '@/scripts/image-utils';
  import { processToZip, MAX_BATCH } from '@/scripts/batch';

  const $ = (id: string) => document.getElementById(id) as HTMLElement;
  const drop = $('rz-drop');
  const input = $('rz-input') as HTMLInputElement;
  const work = $('rz-work');
  const preview = $('rz-preview') as HTMLImageElement;
  const wEl = $('rz-w') as HTMLInputElement;
  const hEl = $('rz-h') as HTMLInputElement;
  const lock = $('rz-lock') as HTMLInputElement;
  const fmt = $('rz-fmt') as HTMLSelectElement;

  const batch = $('rz-batch');
  const batchN = $('rz-batch-n');
  const bwEl = $('rz-bw') as HTMLInputElement;
  const bfmt = $('rz-bfmt') as HTMLSelectElement;
  const batchList = $('rz-batch-list');
  const batchStatus = $('rz-batch-status');
  const batchDl = $('rz-batch-dl') as HTMLButtonElement;

  let current: LoadedImage | null = null;
  let ratio = 1;
  let batchFiles: File[] = [];

  /** Resolve the output type for a given source file, honouring "keep". */
  function targetType(sel: HTMLSelectElement, srcType: string): string {
    if (sel.value === 'keep') return EXT[srcType] ? srcType : 'image/png';
    return sel.value;
  }

  function loadSingle(data: LoadedImage) {
    current = data;
    ratio = data.img.naturalWidth / data.img.naturalHeight;
    wEl.value = String(data.img.naturalWidth);
    hEl.value = String(data.img.naturalHeight);
    preview.src = data.url;
    work.classList.remove('hidden');
  }

  setupDropzone(
    drop, input,
    (data) => { drop.classList.add('hidden'); loadSingle(data); },
    (files) => startBatch(files),
  );

  function startBatch(files: File[]) {
    batchFiles = files.slice(0, MAX_BATCH);
    batchN.textContent = String(batchFiles.length);
    batchList.innerHTML = '';
    for (const f of batchFiles) {
      const li = document.createElement('li');
      const nm = document.createElement('span'); nm.className = 'bl-name'; nm.textContent = f.name;
      const sz = document.createElement('span'); sz.className = 'bl-size'; sz.textContent = `${(f.size / 1024).toFixed(0)} KB`;
      li.append(nm, sz);
      batchList.appendChild(li);
    }
    batchStatus.textContent = files.length > MAX_BATCH ? (batch.dataset.tooMany || '') : '';
    drop.classList.add('hidden');
    work.classList.add('hidden');
    batch.classList.remove('hidden');
  }

  wEl.addEventListener('input', () => {
    if (lock.checked && wEl.value) hEl.value = String(Math.max(1, Math.round(parseInt(wEl.value, 10) / ratio)));
  });
  hEl.addEventListener('input', () => {
    if (lock.checked && hEl.value) wEl.value = String(Math.max(1, Math.round(parseInt(hEl.value, 10) * ratio)));
  });

  const dlBtn = $('rz-dl') as HTMLButtonElement;
  dlBtn.addEventListener('click', async () => {
    if (!current) return;
    const w = Math.max(1, parseInt(wEl.value, 10) || 1);
    const h = Math.max(1, parseInt(hEl.value, 10) || 1);
    const type = targetType(fmt, current.file.type);
    const bg = type === 'image/jpeg' ? '#ffffff' : undefined;
    let url = '';
    dlBtn.disabled = true;
    try {
      const canvas = renderCanvas(current.img, w, h, bg);
      const blob = await canvasToBlob(canvas, type, 0.92);
      url = URL.createObjectURL(blob);
      triggerDownload(url, `${baseName(current.file.name)}-${w}x${h}.${EXT[type]}`);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    } catch {
      if (url) URL.revokeObjectURL(url);
      (window as any).showToast?.(document.body.dataset.error || '');
    } finally {
      dlBtn.disabled = false;
    }
  });

  batchDl.addEventListener('click', async () => {
    if (!batchFiles.length) return;
    batchDl.disabled = true;
    const targetW = Math.max(1, parseInt(bwEl.value, 10) || 1);
    const total = batchFiles.length;
    const procLabel = batch.dataset.processing || 'Processing';
    const res = await processToZip(
      batchFiles,
      async (file) => {
        const { img, url } = await loadImage(file);
        try {
          const w = targetW;
          const h = Math.max(1, Math.round(img.naturalHeight * (targetW / img.naturalWidth)));
          const type = targetType(bfmt, file.type);
          const bg = type === 'image/jpeg' ? '#ffffff' : undefined;
          const canvas = renderCanvas(img, w, h, bg);
          const blob = await canvasToBlob(canvas, type, 0.92);
          return { name: `${baseName(file.name)}-${w}x${h}.${EXT[type]}`, blob };
        } finally {
          URL.revokeObjectURL(url);
        }
      },
      'kelvo-resized.zip',
      (done) => { batchStatus.textContent = `${procLabel}… ${done}/${total}`; },
    );
    batchDl.disabled = false;
    batchStatus.textContent =
      (batch.dataset.done || '') + (res.failed > 0 ? ` — ${batch.dataset.someFailed || ''}` : '');
    (window as any).showToast?.(batch.dataset.done || '');
  });

  function resetAll() {
    if (current) URL.revokeObjectURL(current.url);
    current = null; batchFiles = [];
    input.value = '';
    work.classList.add('hidden');
    batch.classList.add('hidden');
    batchStatus.textContent = '';
    drop.classList.remove('hidden');
  }

  $('rz-reset').addEventListener('click', resetAll);
  $('rz-batch-reset').addEventListener('click', resetAll);
</script>
