---
import type { Locale } from '@/config';
import { SITE } from '@/config';
import { useTranslations } from '@/i18n/ui';
import { homePath } from '@/i18n/utils';

interface Props {
  locale: Locale;
}
const { locale } = Astro.props;
const t = useTranslations(locale);
const year = 2026;
const base = homePath(locale);
const links = [
  { href: `${base}/about`, label: t('footer.about') },
  { href: `${base}/privacy`, label: t('footer.privacyPage') },
  { href: `${base}/terms`, label: t('footer.terms') },
];
---

<footer class="site-footer">
  <div class="container inner">
    <span>© {year} {SITE.name} · {t('footer.privacy')}</span>
    <nav class="footer-links" aria-label={t('footer.navAria')}>
      {
        links.map((l, i) => (
          <>
            <a href={l.href}>{l.label}</a>
            {i < links.length - 1 && <span aria-hidden="true">·</span>}
          </>
        ))
      }
    </nav>
  </div>
</footer>
